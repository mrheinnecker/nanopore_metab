params {
    samplesheet = null
    barcode_dir = null
    outdir = 'results/savont_run'
    threads = 4
    trim_threads = 4
    savont_threads = 4
    taxonomy_threads = 4

    kingdom = 'euk'
    pooled_samples = false

    classifier = 'none'
    savont_db = null
    export_qiime = false
    pr2_db = null
    db_id = 0.7
    db_query_cov = 0.9
    enable_taxonomy_table = true
    enable_biological_report = true

    min_read_length = 1100
    max_read_length = 2000
    quality_value_cutoff = 98
    minimum_base_quality = 25
    min_cluster_size = 12

    rrna_operon = false
    hifi = false
    single_strand = true
    use_hpc = false
    low_polymorphism = false
    mask_low_quality = false

    container = "${projectDir}/containers/savont.sif"

    base_max_forks = 8
    trim_max_forks = 4
    savont_max_forks = 2
    taxonomy_max_forks = 2
    report_max_forks = 1
}

process {
    executor = 'local'
    errorStrategy = 'terminate'
    beforeScript = 'export PATH=/opt/conda/bin:$PATH; export OPENBLAS_NUM_THREADS=1; export OMP_NUM_THREADS=1; export MKL_NUM_THREADS=1; export NUMEXPR_NUM_THREADS=1'

    withLabel: 'savont_base' {
        container = params.container
        cpus = 1
        memory = '4 GB'
        time = '4h'
    }

    withLabel: 'savont_trim18s' {
        container = params.container
        memory = '8 GB'
        time = '24h'
    }

    withLabel: 'savont_asv' {
        container = params.container
        memory = '16 GB'
        time = '48h'
    }

    withLabel: 'savont_classify' {
        container = params.container
        memory = '16 GB'
        time = '24h'
    }

    withLabel: 'savont_taxonomy' {
        container = params.container
        memory = '16 GB'
        time = '24h'
    }

    withLabel: 'savont_report' {
        container = params.container
        cpus = 1
        memory = '4 GB'
        time = '4h'
    }
}

singularity {
    enabled = false
    autoMounts = true
}

apptainer {
    enabled = false
    autoMounts = true
}

report {
    overwrite = true
}

timeline {
    overwrite = true
}

trace {
    overwrite = true
}

profiles {
    singularity {
        singularity.enabled = true
        apptainer.enabled = false
        docker.enabled = false
    }

    apptainer {
        apptainer.enabled = true
        singularity.enabled = false
        docker.enabled = false
    }

    slurm {
        process.executor = 'slurm'
        executor.queueSize = 50
        executor.submitRateLimit = '20 sec'

        process {
            /*
             * Keep small table/report/export steps inside the Nextflow
             * controller job. The read/database-heavy work remains on Slurm.
             */
            withName: /PR2_TAXONOMY_TABLE|SAVONT_BIOLOGICAL_REPORT|SAVONT_EXPORT/ {
                executor = 'local'
                cpus = 1
                memory = '4 GB'
                time = '4h'
                maxForks = 2
            }
        }
    }
}
