Bootstrap: docker
From: quay.io/biocontainers/blast:2.17.0--h66d330f_0

%labels
    Author nanopore_metab
    Description NCBI BLAST+ client for standalone remote ASV searches

%environment
    export PATH=/usr/local/bin:$PATH
    export LC_ALL=C

%test
    blastn -version
    blast_formatter -version

%runscript
    exec "$@"
