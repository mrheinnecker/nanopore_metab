Bootstrap: docker
From: mambaorg/micromamba:1.5.8

%labels
    Author BaNaNA
    Description Standalone Savont runtime with Barrnap, Python trim18s helpers, and pinned Savont build

%post
    micromamba install -y -n base -c conda-forge -c bioconda \
        python=3.12 \
        barrnap=0.9 \
        vsearch=2.8.0 \
        xopen \
        rust \
        cmake \
        make \
        git \
        pkg-config \
        compilers

    export PATH=/opt/conda/bin:$PATH
    rustc --version
    cargo --version

    git clone https://github.com/bluenote-1577/savont.git /opt/savont
    cd /opt/savont
    git checkout e4e499228df50b8e9a4eb64345ef114424a81477
    cargo install --locked --path . --root /usr/local
    micromamba clean --all --yes

%environment
    export PATH=/opt/conda/bin:/usr/local/bin:$PATH
    export OPENBLAS_NUM_THREADS=1
    export OMP_NUM_THREADS=1
    export MKL_NUM_THREADS=1
    export NUMEXPR_NUM_THREADS=1
    export LC_ALL=C

%runscript
    exec "$@"
