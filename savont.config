params {
    samplesheet = null
    outdir = 'results/savont_run'
    threads = 8

    kingdom = 'euk'
    pooled_samples = false

    classifier = 'none'
    savont_db = null
    export_qiime = false

    min_read_length = 1100
    max_read_length = 2000
    quality_value_cutoff = 98
    minimum_base_quality = 25
    min_cluster_size = 12

    rrna_operon = false
    hifi = false
    single_strand = true
    use_hpc = false
    low_polymorphism = false
    mask_low_quality = false

    container = 'containers/savont.sif'
}

process {
    executor = 'local'
    errorStrategy = 'terminate'
    beforeScript = 'export PATH=/opt/conda/bin:/usr/local/bin:$PATH; export OPENBLAS_NUM_THREADS=1; export OMP_NUM_THREADS=1; export MKL_NUM_THREADS=1; export NUMEXPR_NUM_THREADS=1'

    withLabel: 'savont_base' {
        container = params.container
        cpus = 1
        memory = '4 GB'
        time = '4h'
    }

    withLabel: 'savont_trim18s' {
        container = params.container
        memory = '8 GB'
        time = '24h'
    }

    withLabel: 'savont_asv' {
        container = params.container
        memory = '16 GB'
        time = '48h'
    }

    withLabel: 'savont_classify' {
        container = params.container
        memory = '16 GB'
        time = '24h'
    }
}

singularity {
    enabled = false
    autoMounts = true
}

report {
    overwrite = true
}

timeline {
    overwrite = true
}

trace {
    overwrite = true
}

profiles {
    singularity {
        singularity.enabled = true
        docker.enabled = false
    }

    slurm {
        process.executor = 'slurm'
        executor.queueSize = 50
        executor.submitRateLimit = '20 sec'

        process {
            withName: 'PREPARE_READS' {
                memory = '16 GB'
                time = '24h'
            }
        }
    }
}
